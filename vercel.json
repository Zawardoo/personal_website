{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "functions": {
    "api/contact.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
